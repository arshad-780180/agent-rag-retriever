# Copy this file to .env and fill in real values. Never commit the real .env file.

PORT=4000

# Set this to any random string you choose, then enter the SAME string
# as the "Secret" when you create the webhook in your GitHub repo settings
# (Settings -> Webhooks -> Add webhook -> Secret).
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# A GitHub Personal Access Token with "repo" scope, used by Agent 4 to
# push branches and open pull requests on your behalf.
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_personal_access_token_here
